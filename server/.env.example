# Server port
PORT=3030

# MongoDB connection URI
MONGODB_URI=mongodb://localhost:27017/NDSCoffee

# Admin credentials
# Generate a bcrypt hash with: node -e "const b=require('bcrypt');b.hash('yourPassword',12).then(console.log)"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$12$examplehashgoeshere

# Allowed client origins (comma-separated for multiple)
CLIENT_URL=http://localhost:3000
